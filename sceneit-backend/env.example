# ─── App ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── TMDB ────────────────────────────────────────────────────────────────────
# Get your key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ─── Redis ───────────────────────────────────────────────────────────────────
# Local dev: redis://localhost:6379
# Upstash production: rediss://default:<password>@<host>:6380
REDIS_URL=redis://localhost:6379

# ─── Scraping ────────────────────────────────────────────────────────────────
# How long to cache a user's scraped watchlist (seconds). Default: 8 hours.
WATCHLIST_CACHE_TTL=28800
# How long to cache a TMDB movie lookup (seconds). Default: 24 hours.
TMDB_CACHE_TTL=86400
# Milliseconds to wait between paginated Letterboxd requests (be polite)
SCRAPE_DELAY_MS=800
# Max concurrent watchlist page requests per user
SCRAPE_CONCURRENCY=3

# ─── Rate limiting ───────────────────────────────────────────────────────────
# Max compare requests per IP per minute
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000
